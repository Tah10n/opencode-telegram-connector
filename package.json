{
  "name": "telegram-opencode-connector",
  "description": "Bridge Telegram chats/topics to opencode sessions with per-thread project bindings, message mirroring, and prompt handling.",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "keywords": [
    "telegram",
    "bot",
    "connector",
    "opencode",
    "cli"
  ],
  "files": [
    "src",
    "scripts/check-syntax.mjs",
    "scripts/verify-callback-data.mjs",
    "index.mjs",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md",
    "RELEASING.md",
    ".env.example",
    "connector.config.example.mjs"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "telegram-opencode-connector": "./src/cli.js"
  },
  "scripts": {
    "start": "node src/cli.js",
    "check": "node scripts/check-syntax.mjs && node scripts/verify-callback-data.mjs && npm run check:architecture && npm run check:types",
    "check:architecture": "node scripts/verify-architecture.mjs",
    "check:types": "tsc -p tsconfig.check.json",
    "setup:check": "node src/cli.js check",
    "lint": "npm run check",
    "test": "node --test",
    "test:platform": "node --test test/launcher.test.js test/overview.test.js test/index.integration.test.js",
    "test:coverage": "node --test --experimental-test-coverage"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
