# Guided setup:
# - copy connector.config.example.mjs to connector.config.mjs
# - fill in this file
# - run npm run setup:check before npm start

# Telegram
TELEGRAM_BOT_TOKEN=123456789:replace_me
TELEGRAM_ALLOWED_USER_ID=123456789

# Preferred setup:
# - copy connector.config.example.mjs to connector.config.mjs
# - keep secrets like TELEGRAM_BOT_TOKEN / TELEGRAM_ALLOWED_USER_ID here

# Optional example credentials used by connector.config.example.mjs
# REMOTE_OPENCODE_USERNAME=opencode
# REMOTE_OPENCODE_PASSWORD=replace_me

# Legacy projects config fallback (optional; only needed if you do not use connector.config.mjs)
# Pick one:
# PROJECTS_FILE=./projects.json
# PROJECTS_JSON={"localDesktop":{"baseUrl":"http://127.0.0.1:4100"}}

# If you use the legacy PROJECTS_FILE / PROJECTS_JSON format with directory+port+autoStart, baseUrl is optional.

# Optional: default project hint for unbound threads
# DEFAULT_PROJECT=localDesktop

# Optional: override state file path (default: ./.data/state.json)
# STATE_FILE=./.data/state.json

# Safety: if a project uses Basic Auth password and connects to a non-loopback http:// URL,
# the connector refuses to start unless you explicitly allow it:
# OPENCODE_ALLOW_INSECURE_HTTP=1

# Optional: prefix for TG -> OpenCode (default: empty)
# TG_PREFIX=

# Optional: echo filter mode for OpenCode -> TG mirroring
# ECHO_FILTER_MODE=recent|prefix

# Optional: mirror user messages typed in opencode TUI to the bound Telegram thread (default: off)
# MIRROR_TUI_USER_MESSAGES=1

# Optional: log output format for supervisors/hosted runtimes
# CONNECTOR_LOG_FORMAT=text|json

# Optional: no-dependency HTTP health endpoints for local supervisors/probes.
# Disabled by default and loopback-bound by default; this is not webhook support.
# CONNECTOR_HEALTH_ENABLED=0
# CONNECTOR_HEALTH_HOST=127.0.0.1
# CONNECTOR_HEALTH_PORT=8787

# Optional Telegram workflow limits (integers; connector.config.mjs `limits` is preferred)
# TG_ATTACHMENT_CONFIRM_BYTES=32768
# TG_ATTACHMENT_MAX_BYTES=262144
# TG_CHANGED_FILES_LIMIT=10
# TG_INLINE_DIFF_TEXT_MAX_CHARS=2500
# TG_STREAM_PREVIEW_MAX_CHARS=3500
# TG_TEXT_ATTACHMENT_THRESHOLD=12000

# Advanced debug options (optional)
# DEBUG_SSE_ROUTING=localDesktop
# MIRROR_COMPACTION=1
# OPENCODE_SERVER_DEBUG=1

# Advanced SSE safety limits (optional; byte values)
# OPENCODE_SSE_MAX_LINE_BYTES=8388608
# OPENCODE_SSE_MAX_EVENT_BYTES=8388608
# OPENCODE_SSE_MAX_EVENT_LINES=5000
# OPENCODE_SSE_HEALTHCHECK_MIN_INTERVAL_MS=15000

# Optional on Linux: choose the preferred terminal launcher for TUI/attach windows
# OPENCODE_TERMINAL=gnome-terminal
